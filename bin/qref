#!/usr/bin/env bash
set -euo pipefail

ROOT="${QUICKREF_DIR:-$HOME/github/quickref}"
NOTES_ROOT="${QUICKREF_NOTES_DIR:-$ROOT/notes}"
INDEX_FILE="$NOTES_ROOT/index.md"
STL_ROOT="$NOTES_ROOT/commands/cpp-stl"
STL_INDEX_FILE="$STL_ROOT/index.md"
USE_FZF=1
USE_PREVIEW=1

if [[ "${QUICKREF_NO_FZF:-0}" == "1" ]]; then
  USE_FZF=0
fi

if [[ "${QUICKREF_NO_PREVIEW:-0}" == "1" ]]; then
  USE_PREVIEW=0
fi

if [[ ! -d "$ROOT" ]]; then
  echo "quickref directory not found: $ROOT" >&2
  exit 1
fi

if [[ ! -d "$NOTES_ROOT" ]]; then
  echo "quickref notes directory not found: $NOTES_ROOT" >&2
  exit 1
fi

open_in_editor() {
  local file="$1"
  local line="${2:-}"

  if [[ "${QUICKREF_NO_OPEN:-0}" == "1" ]]; then
    if [[ -n "$line" ]]; then
      echo "$file:$line"
    else
      echo "$file"
    fi
    return 0
  fi

  if ! command -v nvim >/dev/null 2>&1; then
    echo "nvim is required but not found in PATH" >&2
    exit 1
  fi

  if [[ -n "$line" ]]; then
    exec nvim "+${line}" "$file"
  fi

  exec nvim "$file"
}

pick_file_with_preview() {
  local prompt="$1"
  local files="$2"
  local choice

  if [[ -z "$files" ]]; then
    return 1
  fi

  if [[ "$USE_FZF" -eq 1 ]] && command -v fzf >/dev/null 2>&1; then
    if [[ "$USE_PREVIEW" -eq 1 ]]; then
      choice="$(printf '%s\n' "$files" \
        | fzf --prompt="$prompt" \
              --preview 'sed -n "1,200p" {}' \
              --preview-window=right:60%)" || return 1
    else
      choice="$(printf '%s\n' "$files" | fzf --prompt="$prompt")" || return 1
    fi
  else
    choice="$(printf '%s\n' "$files" | head -n 1)"
  fi

  open_in_editor "$choice"
}

print_stl_topics() {
  cat <<'EOF'
Available STL quick-access topics:

Containers:
vector
deque
list
array
set
map
unordered_set
unordered_map
stack
queue
priority_queue

Algorithms:
sort
lower_bound
binary_search
find
count
accumulate
all_of
any_of
transform
remove
unique
reverse
next_permutation
iota

Other:
algorithms
iterators
utilities
common
pair
tuple
optional
variant
lambda
move
swap

Usage:
  ref <topic>      # e.g. ref vector
  ref stl          # open full STL quick reference
  ref stl-list     # show this topic list
EOF
}

is_stl_topic() {
  local topic="$1"
  case "$topic" in
    vector|deque|list|array|set|map|unordered_set|unordered_map|stack|queue|priority_queue|algorithms|iterators|utilities|common|sort|lower_bound|binary_search|find|count|accumulate|all_of|any_of|transform|remove|unique|reverse|next_permutation|iota|pair|tuple|optional|variant|lambda|move|swap)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

open_stl_reference() {
  if [[ ! -f "$STL_INDEX_FILE" ]]; then
    echo "C++ STL quick reference not found: $STL_INDEX_FILE" >&2
    exit 1
  fi

  pick_file_with_preview 'stl> ' "$STL_INDEX_FILE"
}

open_stl_topic() {
  local topic="$1"

  local file="$STL_ROOT/$topic.md"

  case "$topic" in
    vector|deque|list|array|set|map|unordered_set|unordered_map|stack|queue|priority_queue|algorithms|iterators|utilities|common)
      ;;
    sort|lower_bound|binary_search|find|count|accumulate|all_of|any_of|transform|remove|unique|reverse|next_permutation|iota)
      file="$STL_ROOT/algorithms.md"
      ;;
    pair|tuple|optional|variant|lambda|move|swap)
      file="$STL_ROOT/utilities.md"
      ;;
    *)
      echo "Unknown STL topic: $topic" >&2
      exit 1
      ;;
  esac

  if [[ ! -f "$file" ]]; then
    echo "C++ STL topic not found: $file" >&2
    exit 1
  fi

  pick_file_with_preview 'stl> ' "$file"
}

open_file_picker() {
  local files

  if command -v fd >/dev/null 2>&1; then
    files="$({ fd . "$NOTES_ROOT" --type f --hidden --follow --exclude .git; } | awk '!/\/index\.md$/' | sort)"
  else
    files="$({ find "$NOTES_ROOT" -type f ! -path '*/.git/*' | sort; } | awk '!/\/index\.md$/' )"
  fi

  if [[ -z "$files" ]]; then
    echo "No note files found under: $NOTES_ROOT" >&2
    return 1
  fi

  pick_file_with_preview 'quickref files> ' "$files"
}

open_search_result() {
  local query="$1"

  if ! command -v rg >/dev/null 2>&1; then
    echo "ripgrep (rg) is required for search mode." >&2
    exit 1
  fi

  local matches
  matches="$(rg --line-number --no-heading --smart-case --color=never --glob '!**/index.md' "$query" "$NOTES_ROOT" || true)"

  if [[ -z "$matches" ]]; then
    echo "No matches for: $query" >&2
    exit 1
  fi

  local files
  files="$(printf '%s\n' "$matches" | cut -d: -f1 | awk '!seen[$0]++')"

  pick_file_with_preview 'quickref matches> ' "$files"
}

if [[ $# -eq 1 && "$1" == "--help" ]]; then
  if [[ ! -f "$INDEX_FILE" ]]; then
    echo "quickref index not found: $INDEX_FILE" >&2
    exit 1
  fi

  open_in_editor "$INDEX_FILE"
elif [[ $# -eq 1 ]]; then
  arg_lower="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"

  case "$arg_lower" in
    stl|cpp-stl|c++-stl|--stl)
      open_stl_reference
      ;;
    stl-list|--stl-list|list-stl|stls)
      print_stl_topics
      ;;
    *)
      if is_stl_topic "$arg_lower"; then
        open_stl_topic "$arg_lower"
      else
        open_search_result "$*"
      fi
      ;;
  esac
elif [[ $# -eq 0 ]]; then
  open_file_picker
else
  open_search_result "$*"
fi
